{
  "name": "quick-input-nest-rxdb",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/server/main.ts",
    "dev:client": "vite",
    "check": "tsc --noEmit",
    "build": "bun run check; vite build",
    "start": "bun run src/server/main.ts",
    "smoke": "bun run scripts/smoke.ts",
    "e2e": "bun run build; bun run scripts/e2e.ts"
  },
  "dependencies": {
    "@tanstack/solid-router": "^1.120.5",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "express": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxdb": "^16.20.0",
    "rxjs": "^7.8.2",
    "solid-js": "^1.9.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9",
    "supertest": "^7.1.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7",
    "vite-plugin-pwa": "^1.0.1",
    "vite-plugin-solid": "^2.11.0"
  }
}

